# cp deploy/env.example .env.dev, then fill in MISTRAL_API_KEY.
# Read by `just migrate` and by the compose services.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=answer_service
POSTGRES_PASSWORD=answer_service
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=answer_service
POSTGRES_DRIVER=asyncpg

# --- SQLAlchemy engine / session -------------------------------------------
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_ECHO=false
DB_AUTO_FLUSH=false
DB_EXPIRE_ON_COMMIT=false
DB_FUTURE=true

# --- NATS (task broker; the server must run with --jetstream) ---------------
NATS_HOST=localhost
NATS_PORT=4222
NATS_USER=
NATS_PASSWORD=

# --- Redis (the three database indexes must differ) -------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_WORKER_DB=1
REDIS_SCHEDULE_SOURCE_DB=2
REDIS_CACHE_DB=0

# --- taskiq behaviour -------------------------------------------------------
TASKIQ_SUBJECT=answer_service.tasks
TASKIQ_STREAM_NAME=answer_service_jetstream
TASKIQ_DURABLE=answer_service_durable
TASKIQ_QUEUE=answer_service_workers
TASKIQ_RESULT_EX_TIME=1000
TASKIQ_DEFAULT_RETRY_COUNT=3
TASKIQ_DEFAULT_DELAY=5.0
TASKIQ_USE_JITTER=true
TASKIQ_USE_DELAY_EXPONENT=true
TASKIQ_MAX_DELAY_EXPONENT=60.0

# --- Qdrant (unreachable Qdrant fails the boot, by design) ------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=qa_pairs
QDRANT_USE_HTTPS=false
QDRANT_PREFER_GRPC=false

# --- Mistral (the dimension is baked into the collection at creation) -------
MISTRAL_API_KEY=
MISTRAL_BASE_URL=
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_EMBEDDING_DIMENSION=1024
MISTRAL_CHAT_MODEL=mistral-large-latest
MISTRAL_TEMPERATURE=0.0
MISTRAL_MAX_CONCURRENCY=5

# --- Uploaded source files (shared by the api and the worker) ---------------
SOURCE_STORAGE_DIRECTORY=var/uploads

# --- HTTP server ------------------------------------------------------------
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8080
FASTAPI_DEBUG=false
FASTAPI_ALLOW_CREDENTIALS=false

# --- Logging (PATH_TO_SAVE_LOGS, not PATH: EnvSource matches by field name) -
LOG_LEVEL=INFO
RENDER_JSON_LOGS=false
PATH_TO_SAVE_LOGS=
