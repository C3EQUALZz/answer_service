# cp deploy/env.example .env.dev, then fill in MISTRAL_API_KEY.
# Read by `just migrate` and by the compose services.

# --- Postgres ---------------------------------------------------------------
# The cluster is initialised with scram-sha-256 and deploy/prod/postgres/
# pg_hba.conf rejects anything outside the private ranges, so this user is
# reachable only from the compose network.
POSTGRES_USER=answer_service
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=answer_service
POSTGRES_DRIVER=asyncpg

# --- SQLAlchemy engine / session -------------------------------------------
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_ECHO=false
DB_AUTO_FLUSH=false
DB_EXPIRE_ON_COMMIT=false
DB_FUTURE=true

# --- NATS (task broker) -----------------------------------------------------
# deploy/prod/nats/nats.conf declares exactly one user and expands these two
# variables into it, so the same pair is both the server's account and the
# client's credential. Leaving them empty is not anonymous access — the server
# refuses to start.
#
# The user is restricted to `answer_service.>`, `$JS.API.>` and `_INBOX.>`.
# TASKIQ_SUBJECT and TASKIQ_STREAM_NAME must stay under that prefix.
NATS_HOST=localhost
NATS_PORT=4222
NATS_USER=answer_service
NATS_PASSWORD=change-me-nats

# --- Redis (the three database indexes must differ) -------------------------
# Two principals, deliberately:
#
#   REDIS_DEFAULT_PASSWORD  the `default` ACL user. Operator access, read by
#                           deploy/prod/redis/redis_entrypoint.sh and by the
#                           container healthcheck. The application never uses it.
#   REDIS_USER / REDIS_PASSWORD
#                           the application's own ACL user, granted +@all minus
#                           @admin and @dangerous.
#
# REDIS_USER without REDIS_PASSWORD fails the config load: an ACL user with no
# password cannot authenticate, and the connection would silently fall back.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DEFAULT_PASSWORD=change-me-redis-admin
REDIS_USER=answer_service
REDIS_PASSWORD=change-me-redis-app
REDIS_WORKER_DB=1
REDIS_SCHEDULE_SOURCE_DB=2
REDIS_CACHE_DB=0

# --- taskiq behaviour -------------------------------------------------------
TASKIQ_SUBJECT=answer_service.tasks
TASKIQ_STREAM_NAME=answer_service_jetstream
TASKIQ_DURABLE=answer_service_durable
TASKIQ_QUEUE=answer_service_workers
TASKIQ_RESULT_EX_TIME=1000
TASKIQ_DEFAULT_RETRY_COUNT=3
TASKIQ_DEFAULT_DELAY=5.0
TASKIQ_USE_JITTER=true
TASKIQ_USE_DELAY_EXPONENT=true
TASKIQ_MAX_DELAY_EXPONENT=60.0

# --- Qdrant (unreachable Qdrant fails the boot, by design) ------------------
# Self-hosted Qdrant does not issue an API key — nobody hands you one. You pick
# the value, and compose passes the same string to the server as
# QDRANT__SERVICE__API_KEY and to the client as QDRANT_API_KEY. Anything works;
# generate one with `openssl rand -hex 32`.
# On Qdrant Cloud it comes from the cluster's console instead, and QDRANT_HOST
# becomes the cluster URL with QDRANT_USE_HTTPS=true.
#
# The key travels in a header in cleartext, so it is only meaningful while the
# port stays on a private network or TLS is terminated in front of it.
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=change-me-qdrant
QDRANT_COLLECTION_NAME=qa_pairs
QDRANT_USE_HTTPS=false
QDRANT_PREFER_GRPC=false

# --- Mistral (the dimension is baked into the collection at creation) -------
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_EMBEDDING_DIMENSION=1024
MISTRAL_CHAT_MODEL=mistral-large-latest
MISTRAL_TEMPERATURE=0.0
MISTRAL_MAX_CONCURRENCY=5

# --- Uploaded source files (shared by the api and the worker) ---------------
SOURCE_STORAGE_DIRECTORY=var/uploads

# --- HTTP server ------------------------------------------------------------
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8080
FASTAPI_DEBUG=false
FASTAPI_ALLOW_CREDENTIALS=false

# --- Logging (PATH_TO_SAVE_LOGS, not PATH: EnvSource matches by field name) -
LOG_LEVEL=INFO
RENDER_JSON_LOGS=false
PATH_TO_SAVE_LOGS=
