[run]
parallel = True
data_file = .coverage
source = src
omit =
    tests/*
    src/answer_service/_version.py
    ; Entry points: assembly only, and nothing to assert without standing the
    ; process up. What they build is covered through the integration container.
    src/answer_service/fastapi_app.py
    src/answer_service/worker_app.py
    src/answer_service/scheduler_app.py
    src/answer_service/infrastructure/persistence/migrations/*

[report]
show_missing = True
skip_covered = True
exclude_lines =
    pragma: no cover
    pragma: no coverage
    if TYPE_CHECKING:
    ^\s*\.\.\.$
    @(abc\.)?abstractmethod
